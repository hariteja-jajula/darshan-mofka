# local builds and installs
/darshan-install/
/darshan-install-*/
/darshan-logs/
/darshan/_build*/
/darshan/install*/
/diaspora-stream-api/_build*/
/diaspora-stream-api/install/

# demo build outputs (compiled workload binaries)
/workloads/c/mofka_forward_smoke
/workloads/c/mofka_forward_mpiio
/workloads/mpi/mofka_forward_mpiio

# PBS job stdout/stderr copied into results/ by submit.sh
/results/*.OU
/results/*.o[0-9]*

# OpenMPI per-rank crash backtraces (host.rank.pid) dropped in the repo root
/i[0-9]*.[0-9]*.[0-9]*
/*.btr

# broker runtime outputs
/server/mofka.json
/server/bedrock.log
/server/bedrock.pid

# machine-specific environment
/server/env.local.sh

# automated setup build outputs (rebuilt by install/setup.sh from install/config.yaml)
/install/_spack/
/install/_venv/
/install/_mofka/
/server/_mongo_env/
/Database/_mongo_env/

# per-run result folders (keep results/README.md)
/results/*/

# env-snapshot: diagnostic dump (contains machine-specific PATH/user paths).
# Regenerate with server/capture-env.sh; do not commit (would leak user paths).
/server/env-snapshot/

# job run outputs and artifacts
/server/_pbs_*/
/server/_diag_*/
/server/_scale_*/
/server/_flowcept_run/
*.o[0-9]*
/data/
/hydra_log/

# generated files and crashes
*.o
*.log
*.pyc
core
core.*
__pycache__/


# overnight driver logs
/overnight_logs/
