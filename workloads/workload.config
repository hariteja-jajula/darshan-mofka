# workload.config -- WHAT to run and WHERE it runs.
# (HOW it streams -- broker, connector, Darshan env, sink -- is in server/server.config.)
# Edit this file, then: PBS_ACCOUNT=<acct> bash submit.sh   (or override any key with an
# env var of the same UPPERCASE name, e.g. EVENTS=50000 NODES=2).

workload: c              # c | python-ml
events: 8                # scale knob: training steps / write-events
checkpoints: 2           # number of checkpoints across the run
reps: 1                  # repeat the whole run N times (variance / overhead A-B)

topology:
  nodes: 1               # nodes to request
  tasks: 1               # workload processes / MPI ranks
  placement: colocated # colocated (workload shares a broker node) | separate (own node)
  brokers: 1            # 1 (single broker) | per-node (one bedrock per node, MPI-bootstrapped)

pbs:                     # submit-time; submit.sh reads these to size the qsub
  account: radix-io
  queue: debug
  walltime: "00:30:00"
  ncpus: 32
