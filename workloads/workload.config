# workload.config -- the PRODUCER/workload side: what to run, where, and how it is
# instrumented. (Broker knobs are in server/server.config; consumer + Mongo sink are in
# Client/client.config.) Edit here, then: PBS_ACCOUNT=<acct> bash submit.sh.
# Override any key with an env var of the same UPPERCASE name (e.g. EVENTS=50000 NODES=2).

workload: c              # c | python-ml
events: 8                # scale knob: training steps / write-events
checkpoints: 2           # number of checkpoints across the run
reps: 1                  # repeat the whole run N times (variance / overhead A-B)

topology:
  nodes: 1               # nodes to request
  tasks: 1               # workload processes / MPI ranks
  placement: colocated   # colocated (workload shares a broker node) | separate (own node)
  brokers: 1             # 1 (single broker) | per-node (one bedrock per node, MPI-bootstrapped)

connector:               # producer knobs -> DARSHAN_MOFKA_*
  enable: 1              # master on/off: 0 = runtime-only baseline (no streaming), 1 = stream
  batch: 0              # DARSHAN_MOFKA_BATCH        (0 = adaptive)
  max_batches: 64       # DARSHAN_MOFKA_MAX_BATCHES  (pending-batch cap; backpressure point)
  flush_ms: 5000        # DARSHAN_MOFKA_FLUSH_MS     (final drain wait; raise for big backlogs)
  timing: 1             # DARSHAN_MOFKA_TIMING       (per-call latency to stderr; overhead studies)

darshan:                 # standard Darshan runtime env -> DARSHAN_*
  enable_nonmpi: 1       # DARSHAN_ENABLE_NONMPI (REQUIRED for the non-MPI c/python-ml workloads)
  modmem:                # DARSHAN_MODMEM MiB (blank = 4); biggest lever on how much I/O is captured
  mod_enable:            # DARSHAN_MOD_ENABLE  CSV modules to force on  (e.g. DXT_POSIX)
  mod_disable:           # DARSHAN_MOD_DISABLE CSV modules to turn off   (trim event volume)
  internal_timing:       # DARSHAN_INTERNAL_TIMING 1 = print startup/shutdown time

pbs:                     # submit-time; submit.sh reads these to size the qsub
  account: radix-io
  queue: debug
  walltime: "00:30:00"
  ncpus: 32
