# workload.config -- the ONE place to choose what to run and how big.
# Edit this file (or override any key with an env var of the same UPPERCASE name).
# The event count is derived from the two knobs and printed before the run.
#
#   C workload:        POSIX events = events + 2 ; STDIO events = 3 * checkpoints
#   python-ml:         events -> ML_EPOCHS ; checkpoints -> checkpoint writes

workload: c            # c | python-ml | mpi | dlio
events: 8              # generic scale knob (training steps / epochs)
checkpoints: 2         # number of checkpoints across the run

connector:             # producer-side Darshan->Mofka knobs
  batch: 0             # DARSHAN_MOFKA_BATCH   (0 = adaptive)
  max_batches: 64      # DARSHAN_MOFKA_MAX_BATCHES
  timing: 1            # DARSHAN_MOFKA_TIMING  (per-call timing to stderr)
  flush_ms: 5000       # DARSHAN_MOFKA_FLUSH_MS (final-flush wait)
