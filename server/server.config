# server.config -- the ONE place for broker + sink knobs. Edit this file (or override
# any key with an env var of the same UPPERCASE name, e.g. MOFKA_PROTOCOL, PARTITIONS).

protocol: auto           # auto = profile default (verbs on lcrc, ofi+tcp on polaris); or verbs | tcp | ofi+tcp
topic: darshan           # single source of truth for the topic name (producer + broker + consumer)
partitions: 1            # number of partitions to create for the topic
partition_type: memory   # memory | default

mongo:
  db: darshan_stream     # MongoDB database the FlowCept consumer drains into
  port: 27017            # mongod port
