# server.config -- HOW the pipeline streams: broker + connector + Darshan env + sink.
# (WHAT runs is in workloads/workload.config.) Edit here, or override any key with an env
# var of the same UPPERCASE name (e.g. MOFKA_PROTOCOL, PARTITIONS, DARSHAN_MODMEM).

protocol: auto           # auto -> profile default (tcp on Improv, ofi+tcp on Polaris); or verbs | tcp | ofi+tcp
topic: darshan           # single source of truth for the topic name (producer + broker + consumer)
partitions: 1            # number of partitions to create for the topic
partition_type: memory   # memory | default (on-disk; requires partition_opts below)

connector:               # producer knobs -> DARSHAN_MOFKA_*
  enable: 1              # master on/off: 0 = runtime-only baseline (no streaming), 1 = stream
  batch: 0              # DARSHAN_MOFKA_BATCH        (0 = adaptive)
  max_batches: 64       # DARSHAN_MOFKA_MAX_BATCHES  (pending-batch cap; backpressure point)
  flush_ms: 5000        # DARSHAN_MOFKA_FLUSH_MS     (final drain wait; raise for big backlogs)
  timing: 1             # DARSHAN_MOFKA_TIMING       (per-call latency to stderr; overhead studies)

darshan:                 # standard Darshan runtime env -> DARSHAN_*
  enable_nonmpi: 1       # DARSHAN_ENABLE_NONMPI (REQUIRED for the non-MPI c/python-ml workloads)
  modmem:                # DARSHAN_MODMEM MiB (blank = 4); biggest lever on how much I/O is captured
  mod_enable:            # DARSHAN_MOD_ENABLE  CSV modules to force on  (e.g. DXT_POSIX)
  mod_disable:           # DARSHAN_MOD_DISABLE CSV modules to turn off   (trim event volume)
  internal_timing:       # DARSHAN_INTERNAL_TIMING 1 = print startup/shutdown time (pairs w/ connector.timing)

mongo:
  db: darshan_stream     # MongoDB database the FlowCept consumer drains into
  port: 27017            # mongod port
  cache_gb:              # mongod --wiredTigerCacheSizeGB (blank = default; set on shared nodes)
  dbpath:                # mongod --dbpath (blank = per-run dir; point at node-local SSD for speed)

consumer:                # FlowCept settings, rendered into flowcept_settings.yaml
  mq_buffer_size: 50     # events buffered before insert
  mq_flush_secs: 5       # max wait before flushing the mq buffer
  db_buffer_size: 50     # DocumentInserter batch size to mongo
  db_flush_secs: 5       # mongo-insert flush interval

broker:                  # rendered into bedrock-config.json (advanced)
  rpc_thread_count: 4    # margo RPC servicing threads (server concurrency)
  use_progress_thread: true
  master_db: map         # map | rocksdb  (rocksdb also needs master_db_path)
  master_db_path:        # dir for the rocksdb master DB (only when master_db: rocksdb)

partition_opts:          # only used when partition_type: default (on-disk)
  path:                  # dir for on-disk chunk files   (REQUIRED for default)
  abt_io: io_controller  # abt-io instance name           (REQUIRED for default)
  sync: true             # fdatasync per batch (durability vs speed)
