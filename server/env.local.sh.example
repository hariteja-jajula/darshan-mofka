#!/bin/bash
# Per-machine settings for the darshan -> mofka mini stack.
#
# Copy this to "env.local.sh" (same directory) and fill in the values for YOUR
# cluster. env.sh sources it automatically if present. This is the ONLY file
# you should need to touch when porting to a new machine -- everything else
# derives from repo layout.
#
# Every variable is optional: if the tool is already on PATH / LD_LIBRARY_PATH
# you can leave the corresponding line blank.

# --- MPI launcher -------------------------------------------------------------
# On module-based clusters, load the MPI you want to use as the launcher. The
# MPI is used ONLY to place one process per node; mofka/bedrock do their own
# networking over libfabric, so any MPI works.
#   module load openmpi/4.1.8            # e.g. Improv (LCRC)
#   module load cray-pals                # e.g. Polaris (ALCF)
# If mpiexec is not on PATH after loading, point at it explicitly:
#   export MPIEXEC=/path/to/mpiexec

# --- mofka / bedrock stack ----------------------------------------------------
# A spack view (or any prefix) that provides bin/bedrock and the mofka libs.
#   export MOFKA_SPACK_VIEW=/path/to/spack/var/spack/environments/<env>/.spack-env/view

# --- diaspora-c bindings ------------------------------------------------------
# Install prefix with lib/libdiaspora-stream-api.* and include/diaspora/*.hpp
#   export DIASPORA_C=/path/to/diaspora-c-install

# --- python that can `import mochi.mofka` (for mofkactl / consume.py) ----------
#   export PYPREFIX=/path/to/python-prefix          # adds bin + lib
#   export PY=/path/to/python-prefix/bin/python3    # exact interpreter
#   export MOFKA_PYTHONPATH=/path/to/site-packages:/more/site-packages

# --- transport (optional) -----------------------------------------------------
#   export MOFKA_PROTOCOL=ofi+tcp        # default; use e.g. ofi+verbs on IB

# --- darshan (optional; defaults to <repo>/darshan-install) --------------------
#   export DARSHAN_PREFIX=/path/to/darshan-install
