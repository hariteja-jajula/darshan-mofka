#!/bin/bash
# Per-machine settings for the darshan -> mofka harness.
#
# Copy this to "env.local.sh" (same directory). env.sh sources it automatically.
#
# You normally only need the `module load` line: env.sh AUTO-DISCOVERS the stack
# paths (DIASPORA_C, MOFKA_SPACK_VIEW, DARSHAN_PREFIX, PY) from conventional
# locations -- built into the workspace, or one/two levels up. Set a variable
# here ONLY to override discovery (non-standard layout).

# --- module loads (the one machine-specific thing that can't be discovered) ---
# Lmod may not be initialised in PBS batch shells -- bootstrap it, then load the
# compiler + an MPI launcher. Use the toolchain diaspora-c was built with.
if ! command -v module >/dev/null 2>&1; then
    for _f in /etc/profile.d/z00_lmod.sh /etc/profile.d/lmod.sh; do
        [ -f "$_f" ] && { source "$_f"; break; }
    done
fi
module load gcc/13.2.0 openmpi/4.1.8 || true    # e.g. Improv (LCRC)

# --- transport (optional; env.sh defaults to ofi+tcp) -------------------------
export MOFKA_PROTOCOL="${MOFKA_PROTOCOL:-ofi+verbs}"

# --- overrides ONLY if auto-discovery can't find them -------------------------
#   export DIASPORA_C=/path/to/diaspora-c-install       # has include/diaspora/diaspora_c.h
#   export MOFKA_SPACK_VIEW=/path/to/spack/view         # has bin/bedrock
#   export DARSHAN_PREFIX=/path/to/darshan-install      # has lib/libdarshan.so
#   export PY=/path/to/python                           # can import mochi.mofka
